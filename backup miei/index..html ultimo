<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Genera dinamicamente le 50 miniature della galleria "Scatti dal campo"
  (function () {
    var grid = document.getElementById('gallery-grid');
    if (!grid) return;
    var frag = document.createDocumentFragment();
    for (var n = 1; n <= 50; n++) {
      var name = 'extra' + n;
      var item = document.createElement('div');
      item.className = 'gph';
      item.innerHTML =
        '<img data-name="' + name + '" alt="Foto ' + n + '">' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="7" width="18" height="13" rx="2"/><circle cx="12" cy="13.5" r="3.5"/><path d="M8 7l1.5-3h5L16 7"/></svg>' +
        '<span class="cap">FOTO ' + n + '<br><span class="filename">images/' + name + '.jpg</span></span>';
      frag.appendChild(item);
    }
    grid.appendChild(frag);
    initImageFallbacks(grid);
  })();

  // Prova automaticamente varie estensioni (jpg, jpeg, png, webp) per ogni
  // immagine con attributo data-name, cercando in images/<nome>.<estensione>.
  // Se nessuna versione esiste, il segnaposto resta visibile.
  function initImageFallbacks(scope) {
    var root = scope || document;
    root.querySelectorAll('img[data-name]').forEach(function (img) {
      if (img.dataset.fallbackInit) return;
      img.dataset.fallbackInit = '1';
      var exts = ['jpg', 'jpeg', 'png', 'webp', 'JPG', 'JPEG', 'PNG'];
      var i = 0;
      function tryNext() {
        if (i >= exts.length) { img.remove(); return; }
        img.src = 'images/' + img.dataset.name + '.' + exts[i];
        i++;
      }
      img.onerror = tryNext;
      img.onload = function () {
        var parent = img.parentElement;
        Array.prototype.forEach.call(parent.children, function (el) {
          if (el !== img) el.style.display = 'none';
        });
        // Se l'hero photo si carica, nasconde l'illustrazione di fallback
        var fallbackIll = parent.querySelector && parent.querySelector('.fallback-illustration');
        if (fallbackIll) fallbackIll.style.display = 'none';
      };
      tryNext();
    });
  }
  initImageFallbacks(document);

  // Frecce di scorrimento della galleria
  (function () {
    var grid = document.getElementById('gallery-grid');
    var prev = document.getElementById('gal-prev');
    var next = document.getElementById('gal-next');
    if (!grid || !prev || !next) return;
    var step = 336; // larghezza tile (320px) + gap (16px)
    prev.addEventListener('click', function () { grid.scrollBy({ left: -step, behavior: 'smooth' }); });
    next.addEventListener('click', function () { grid.scrollBy({ left: step, behavior: 'smooth' }); });
  })();

  // Lightbox: clic su una foto caricata per ingrandirla
  (function () {
    var lightbox = document.getElementById('lightbox');
    var lightboxImg = document.getElementById('lightbox-img');
    var closeBtn = document.getElementById('lightbox-close');

    function openLightbox(src, alt) {
      lightboxImg.src = src;
      lightboxImg.alt = alt || '';
      lightbox.classList.add('open');
    }
    function closeLightbox() {
      lightbox.classList.remove('open');
      lightboxImg.src = '';
    }

    document.addEventListener('click', function (e) {
      var img = e.target.closest('.gph img[data-name], .focus-media img[data-name], .about-photo img[data-name]');
      if (img && img.src) openLightbox(img.src, img.alt);
    });
    closeBtn.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', function (e) {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeLightbox();
    });
  })();

  // Animazioni di reveal allo scroll
  (function () {
    var items = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window) || !items.length) {
      items.forEach(function (el) { el.classList.add('in-view'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -60px 0px' });
    items.forEach(function (el) { io.observe(el); });
  })();
</script>

