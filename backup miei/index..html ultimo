<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Andrea Aldrigo & C. — Sementi, Fitosanitari e Concimi a Pernumia</title>
<meta name="description" content="Andrea Aldrigo & C. S.a.s. — rivendita di sementi, prodotti fitosanitari e concimi (dal granulare alla fertirrigazione) a Pernumia, tra Bassa Padovana e Colli Euganei. In collaborazione con il Consorzio CRA.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Libre+Franklin:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --forest: #253B23;
    --forest-deep: #16240F;
    --field: #4B6138;
    --sage-fresh: #7FA05F;
    --wheat: #C9973E;
    --wheat-light: #E7C87C;
    --terracotta: #B15A34;
    --paper: #FBF9F3;
    --paper-warm: #F2EEDE;
    --sage-tint: #EEF1E4;
    --ink: #23271B;
    --ink-soft: #565C4A;
    --line: rgba(35,39,27,0.12);
    --radius: 6px;
    --radius-lg: 14px;
    --ease: cubic-bezier(.22,.75,.28,1);
  }

  *{ box-sizing: border-box; margin:0; padding:0; }
  html{ scroll-behavior: smooth; }
  body{
    background: var(--paper);
    color: var(--ink);
    font-family: 'Libre Franklin', sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3{
    font-family: 'Fraunces', serif;
    font-weight: 600;
    color: var(--forest-deep);
    line-height: 1.15;
  }
  .mono{ font-family: 'Space Mono', monospace; }
  a{ color: inherit; text-decoration: none; }
  img, svg{ display:block; max-width:100%; }
  .wrap{ max-width: 1180px; margin: 0 auto; padding: 0 32px; }

  .eyebrow{
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terracotta);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .eyebrow::before{
    content:"";
    width: 22px;
    height: 1px;
    background: var(--terracotta);
    display: inline-block;
  }

  /* ---------- SCROLL REVEAL ---------- */
  .reveal{
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s var(--ease), transform 0.8s var(--ease);
  }
  .reveal.stagger-2{ transition-delay: 0.09s; }
  .reveal.stagger-3{ transition-delay: 0.18s; }
  .reveal.stagger-4{ transition-delay: 0.27s; }
  .reveal.stagger-5{ transition-delay: 0.36s; }
  .reveal.in-view{ opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce){
    .reveal{ opacity: 1; transform: none; transition: none; }
  }

  /* ---------- HEADER ---------- */
  header{
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251,249,243,0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav-row{
    display:flex;
    align-items:center;
    justify-content: space-between;
    padding: 16px 32px;
    max-width: 1180px;
    margin: 0 auto;
    gap: 20px;
  }
  .wordmark{
    color: var(--forest-deep);
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 20px;
    white-space: nowrap;
  }
  .wordmark span{
    display:block;
    font-family: 'Space Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    font-weight: 400;
    margin-top: 2px;
  }
  nav{ display:flex; gap: 26px; align-items:center; flex-wrap: wrap; }
  nav a{
    color: var(--ink);
    font-size: 14.5px;
    font-weight: 500;
    opacity: 0.78;
    transition: opacity 0.15s ease;
  }
  nav a:hover{ opacity: 1; }
  .btn-call{
    background: var(--forest);
    color: var(--paper) !important;
    padding: 9px 16px;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 13.5px;
    white-space: nowrap;
    opacity: 1 !important;
  }
  .btn-call:hover{ background: var(--forest-deep); }
  #nav-toggle{ display:none; }
  .burger{ display:none; }

  /* ---------- HERO (photographic) ---------- */
  .hero{
    position: relative;
    overflow: hidden;
    background: var(--forest-deep);
    color: var(--paper);
  }
  .hero-photo{
    position:relative;
    width:100%;
    height: 88vh;
    min-height: 560px;
    max-height: 780px;
    overflow: hidden;
  }
  .hero-photo img{
    position:absolute; inset:0; width:100%; height:100%; object-fit:cover;
  }
  .hero-photo .fallback-illustration{
    position:absolute; inset:0; width:100%; height:100%;
  }
  .hero-photo::after{
    content:"";
    position:absolute; inset:0;
    background: linear-gradient(180deg, rgba(22,36,15,0.15) 0%, rgba(22,36,15,0.35) 55%, rgba(22,36,15,0.86) 100%);
  }
  .hero-inner{
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 2;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px 74px;
  }
  .hero-inner-content{ max-width: 640px; }
  .hero h1{
    color: var(--paper);
    font-size: clamp(2.3rem, 4.6vw, 3.6rem);
    max-width: 14ch;
  }
  .hero p.lead{
    margin-top: 20px;
    font-size: 17.5px;
    max-width: 46ch;
    color: #EDE9D8;
  }
  .hero-ctas{ margin-top: 30px; display:flex; gap: 14px; flex-wrap: wrap; }
  .btn{
    display:inline-flex;
    align-items:center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 14.5px;
    border: 1.5px solid transparent;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .btn:hover{ transform: translateY(-2px); }
  .btn-primary{ background: var(--wheat); color: var(--forest-deep); }
  .btn-primary:hover{ background: var(--wheat-light); }
  .btn-ghost{ border-color: rgba(251,249,243,0.45); color: var(--paper); }
  .btn-ghost:hover{ border-color: var(--paper); }

  /* Service strip overlapping hero bottom edge */
  .service-strip{
    position: relative;
    z-index: 5;
    margin-top: -64px;
  }
  .service-strip .wrap{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .service-tile{
    background: var(--paper);
    border-radius: var(--radius-lg);
    padding: 26px 24px;
    box-shadow: 0 18px 44px rgba(22,36,15,0.16);
    display:flex; flex-direction:column; gap: 10px;
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
    border: 1px solid var(--line);
  }
  .service-tile:hover{ transform: translateY(-5px); box-shadow: 0 24px 54px rgba(22,36,15,0.2); }
  .service-tile .icon{ width: 34px; height:34px; color: var(--terracotta); }
  .service-tile h3{ font-size: 17px; }
  .service-tile p{ font-size: 14px; color: var(--ink-soft); }
  .service-tile .go{
    margin-top: 4px; font-family:'Space Mono', monospace; font-size: 12px;
    letter-spacing: 0.06em; color: var(--forest); font-weight: 700;
  }
  @media (max-width: 880px){
    .service-strip .wrap{ grid-template-columns: 1fr; }
    .service-strip{ margin-top: -46px; }
  }

  /* ---------- PARTNER LOGO MARQUEE ---------- */
  .partners{ background: var(--paper); border-bottom: 1px solid var(--line); padding: 110px 0 26px; }
  .partners-label{
    font-family:'Space Mono', monospace; font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--terracotta); margin-bottom: 16px;
  }
  .partners-viewport{ overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
  .partners-track{
    display: flex;
    align-items: center;
    gap: 64px;
    width: max-content;
    animation: partners-scroll 26s linear infinite;
  }
  .partners-viewport:hover .partners-track{ animation-play-state: paused; }
  .partner-logo{
    flex: 0 0 auto;
    height: 68px;
    min-width: 130px;
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }
  .partner-logo img{
    position: absolute; inset: 0; margin: auto;
    height: 100%; width: auto; object-fit: contain;
    filter: grayscale(1) opacity(0.55);
    transition: filter 0.2s ease;
    z-index: 2;
  }
  .partner-logo:hover img{ filter: grayscale(0) opacity(1); }
  .partner-logo .ph{
    font-family:'Space Mono', monospace; font-size: 12px; letter-spacing: 0.08em;
    color: var(--ink-soft); opacity: 0.4;
    border: 1.5px dashed var(--line);
    padding: 10px 22px; border-radius: var(--radius);
  }
  @keyframes partners-scroll{
    from{ transform: translateX(0); }
    to{ transform: translateX(-50%); }
  }

  /* ---------- SECTIONS GENERIC ---------- */
  section{ padding: 96px 0; }
  .section-head{ max-width: 640px; margin-bottom: 48px; }
  .section-head h2{ font-size: clamp(1.7rem, 3vw, 2.3rem); }
  .section-head p{ margin-top: 14px; color: var(--ink-soft); font-size: 16.5px; }
  .section-head.center{ margin-left:auto; margin-right:auto; text-align:center; }
  .section-head.center .eyebrow{ justify-content:center; }
  .section-head.center .eyebrow::before{ display:none; }

  /* Chi siamo — photo + text */
  .about-grid{ display:grid; grid-template-columns: 1fr 1.05fr; gap: 64px; align-items: center; }
  .about-photo{
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/5;
    background: var(--sage-tint);
    border: 1px solid var(--line);
  }
  .about-photo img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition: transform 0.6s var(--ease); }
  .about-photo:hover img{ transform: scale(1.045); }
  .about-photo .ph-fallback{
    position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:10px; color: var(--ink-soft); text-align:center; padding: 20px;
  }
  .about-photo .ph-fallback svg{ width: 32px; height:32px; color: var(--field); opacity: 0.5; }
  .about-photo .ph-fallback .cap{ font-family:'Space Mono', monospace; font-size: 11px; letter-spacing: 0.04em; }
  .about-photo .ph-fallback .filename{ display:block; margin-top:4px; font-size: 10px; opacity: 0.6; }
  .about-photo-tag{
    position:absolute; left: 18px; bottom: 18px; z-index: 4;
    background: rgba(251,249,243,0.94); backdrop-filter: blur(4px);
    padding: 8px 14px; border-radius: var(--radius);
    font-family:'Space Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--forest-deep); font-weight: 700;
  }
  .about-copy .about-lead{
    font-family:'Fraunces', serif; font-size: 23px; color: var(--ink);
    font-weight: 500; line-height: 1.5; margin-bottom: 18px;
  }
  .about-copy p:not(.about-lead){ color: var(--ink-soft); font-size: 16px; line-height: 1.7; margin-bottom: 16px; }
  .about-cta{ margin-top: 22px; }
  @media (max-width: 880px){
    .about-grid{ grid-template-columns: 1fr; gap: 32px; }
    .about-photo{ aspect-ratio: 16/10; }
  }

  /* Mini gallery below chi-siamo */
  .about-gallery{ margin-top: 74px; }
  .mini-slider-label{
    font-family:'Space Mono', monospace; font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--terracotta); margin-bottom: 14px;
  }
  .gallery-slider{ position: relative; }
  .gallery-grid{
    display:flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory;
    padding-bottom: 8px; scrollbar-width: none; -ms-overflow-style: none;
  }
  .gallery-grid::-webkit-scrollbar{ display:none; }
  .gph{
    position: relative; flex: 0 0 auto; width: 320px; scroll-snap-align: start;
    aspect-ratio: 4/3; border-radius: var(--radius); overflow: hidden;
    background: var(--sage-tint); border: 1px solid var(--line);
    display:flex; flex-direction: column; align-items:center;
    justify-content:center; gap: 10px; color: var(--ink-soft); text-align:center; padding: 20px;
  }
  .gph svg{ width: 30px; height:30px; color: var(--field); opacity: 0.5; }
  .gph .cap{ font-family:'Space Mono', monospace; font-size: 11.5px; letter-spacing: 0.04em; }
  .gph .filename{ display:block; margin-top:4px; font-size: 10px; opacity: 0.6; }
  .gph img{
    position: absolute; inset:0; width:100%; height:100%;
    object-fit: cover; z-index: 3; transition: transform 0.5s var(--ease); cursor: zoom-in;
  }
  .gph:hover img{ transform: scale(1.06); }
  .gallery-arrow{
    position:absolute; top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px; border-radius: 50%; background: var(--paper);
    border: 1px solid var(--line); display:flex; align-items:center; justify-content:center;
    cursor:pointer; z-index: 5; box-shadow: 0 8px 22px rgba(22,36,15,0.14);
    transition: background 0.15s ease;
  }
  .gallery-arrow:hover{ background: var(--sage-tint); }
  .gallery-arrow svg{ width: 18px; height:18px; color: var(--forest-deep); }
  .gallery-arrow.prev{ left: -14px; }
  .gallery-arrow.next{ right: -14px; }
  @media (max-width: 620px){
    .gallery-arrow{ display:none; }
    .gph{ width: 78vw; }
  }
  .gallery-note{ margin-top: 18px; font-size: 13.5px; color: var(--ink-soft); font-style: italic; }

  /* CRA band */
  .cra{ background: var(--forest-deep); color: var(--paper); }
  .cra .wrap{ display:grid; grid-template-columns: 0.9fr 1.1fr; gap: 56px; align-items: center; }
  .cra .eyebrow{ color: var(--wheat-light); }
  .cra .eyebrow::before{ background: var(--wheat-light); }
  .cra h2{ color: var(--paper); }
  .cra p{ color: #D9D4BE; margin-top: 16px; font-size: 16px; max-width: 52ch; }
  .cra-badge{ border: 1.5px solid rgba(231,200,124,0.5); border-radius: var(--radius-lg); padding: 28px; }
  .cra-badge .tag{
    font-family:'Space Mono', monospace; font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--wheat-light); margin-bottom: 10px; display:block;
  }
  .cra-badge h3{ color: var(--paper); font-size: 19px; margin-bottom: 12px; }
  .cra-products{ list-style:none; margin-top: 14px; }
  .cra-products li{
    font-size: 14px; padding: 8px 0; border-top: 1px dashed rgba(231,200,124,0.25); color: #EDE9D8;
  }
  .cra-link{
    display:inline-flex; align-items:center; gap:8px; margin-top: 20px; font-size: 14px;
    font-weight: 700; color: var(--wheat-light); border-bottom: 1px solid var(--wheat-light); padding-bottom: 2px;
  }
  @media (max-width: 880px){ .cra .wrap{ grid-template-columns: 1fr; } }

  /* Territorio / Colli Euganei */
  .territorio{ position:relative; background: var(--sage-tint); overflow:hidden; }
  .territorio-banner{
    position:relative;
    border-radius: var(--radius-lg);
    overflow:hidden;
    height: 260px;
    background: linear-gradient(180deg,#EADFC2 0%, #DCCB9E 100%);
  }
  .territorio-banner svg{ width:100%; height:100%; }
  .territorio-text{ max-width: 640px; margin-top: 40px; }
  .territorio-text p{ color: var(--ink-soft); font-size: 16px; margin-top: 14px; }

  /* Focus dal campo: foto in evidenza di grandezze diverse, con didascalia */
  .focus-grid{
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  .focus-item.large{ grid-column: 1 / -1; }
  .focus-item.medium{ grid-column: span 2; }
  .focus-media{
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: #fff;
    border: 1px solid var(--line);
    box-shadow: 0 10px 30px rgba(22,36,15,0.08);
  }
  .focus-item.large .focus-media{ aspect-ratio: 21/8; }
  .focus-item.medium .focus-media{ aspect-ratio: 4/3; }
  .focus-media img{
    position: absolute; inset: 0; width:100%; height:100%; object-fit: cover; z-index: 3;
    transition: transform 0.6s var(--ease); cursor: zoom-in;
  }
  .focus-media:hover img{ transform: scale(1.045); }
  .focus-placeholder{
    position: absolute; inset: 0;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px;
    color: var(--ink-soft); text-align:center; padding: 16px;
  }
  .focus-placeholder svg{ width: 28px; height: 28px; color: var(--field); opacity: 0.5; }
  .focus-placeholder .cap{ font-family:'Space Mono', monospace; font-size: 11px; letter-spacing: 0.04em; }
  .focus-placeholder .filename{ display:block; margin-top:4px; font-size: 10px; opacity: 0.6; }
  .focus-caption{ margin-top: 14px; }
  .focus-caption strong{ display:block; font-family:'Fraunces', serif; font-size: 15.5px; color: var(--ink); margin-bottom: 4px; }
  .focus-caption p{ font-size: 13.5px; color: var(--ink-soft); line-height: 1.55; margin: 0; }
  @media (max-width: 760px){
    .focus-grid{ grid-template-columns: 1fr; }
    .focus-item.medium{ grid-column: 1; }
    .focus-item.large .focus-media{ aspect-ratio: 4/3; }
  }

  /* Prodotti e Servizi */
  .cards{ display:grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 22px; }
  .card{
    position: relative;
    background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg);
    padding: 30px 24px; transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .card:hover{ border-color: var(--wheat); transform: translateY(-4px); box-shadow: 0 16px 34px rgba(22,36,15,0.1); }
  .card .icon{ width: 42px; height: 42px; margin-bottom: 20px; color: var(--field); }
  .card h3{ font-size: 18px; margin-bottom: 10px; }
  .card p{ font-size: 14.5px; color: var(--ink-soft); }
  .card-featured{ border-color: rgba(200,155,60,0.55); }
  .badge-new{
    position: absolute;
    top: -11px; right: 20px;
    background: var(--terracotta);
    color: var(--paper);
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 5px 12px;
    border-radius: var(--radius);
    transform: rotate(3deg);
    box-shadow: 0 3px 8px rgba(0,0,0,0.18);
  }

  /* Contatti */
  .contact-grid{ display:grid; grid-template-columns: 0.9fr 1.1fr; gap: 50px; }
  .contact-list{ list-style:none; }
  .contact-list li{ padding: 20px 0; border-top: 1px solid var(--line); }
  .contact-list li:last-child{ border-bottom: 1px solid var(--line); }
  .contact-list .label{
    font-family:'Space Mono', monospace; font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--terracotta); display:block; margin-bottom: 6px;
  }
  .contact-list .val{ font-size: 17px; font-weight: 600; }
  .contact-list .contact-people{ display: flex; flex-direction: column; gap: 6px; }
  .contact-list .contact-people a{ font-size: 16px; }
  .contact-list .contact-people a:hover{ color: var(--field); }
  .contact-list a.val:hover{ color: var(--field); }
  .map-frame{
    width: 100%; height: 100%; min-height: 320px; border-radius: var(--radius-lg);
    overflow: hidden; border: 1px solid var(--line);
  }
  .map-frame iframe{ width:100%; height:100%; min-height:320px; border:0; }
  @media (max-width: 880px){ .contact-grid{ grid-template-columns: 1fr; } }

  /* Footer */
  footer{ background: var(--forest-deep); color: #C7C3AC; padding: 46px 0 30px; }
  .footer-row{ display:flex; justify-content: space-between; align-items: flex-start; gap: 24px; flex-wrap: wrap; }
  .footer-word{ font-family:'Fraunces', serif; color: var(--paper); font-size: 18px; font-weight: 600; }
  .footer-meta{ font-size: 12.5px; margin-top: 8px; line-height: 1.8; }
  .footer-note{ font-size: 12px; max-width: 340px; color: #A6A18C; }
  .footer-bottom{
    margin-top: 34px; padding-top: 20px; border-top: 1px solid rgba(251,249,243,0.12);
    font-size: 12px; color: #8E8975; display:flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 880px){
    nav{ display:none; }
    .burger{ display:block; background:none; border:none; color: var(--ink); font-size: 22px; cursor:pointer; }
    #nav-toggle:checked ~ nav{
      display:flex; position: absolute; top: 100%; left: 0; right: 0; background: var(--paper);
      flex-direction: column; padding: 18px 32px 26px; gap: 16px; border-bottom: 1px solid var(--line);
    }
    .territorio-banner{ height: 190px; }
  }
  @media (max-width: 520px){
    .cards{ grid-template-columns: 1fr; }
    .wrap, .nav-row{ padding-left: 20px; padding-right: 20px; }
    .hero-photo{ height: 78vh; }
  }

  :focus-visible{ outline: 2.5px solid var(--terracotta); outline-offset: 2px; }

  /* ---------- LIGHTBOX ---------- */
  #lightbox{
    position: fixed; inset: 0; z-index: 200;
    background: rgba(18,26,12,0.94);
    display: none; align-items: center; justify-content: center;
    padding: 40px;
  }
  #lightbox.open{ display: flex; }
